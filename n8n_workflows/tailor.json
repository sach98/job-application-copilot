    {
      "parameters": {
        "jsCode": "// Encode the full role JSON as base64 so the shell command never has to\n// quote arbitrary JD text. tailor.py decodes --input-b64 itself.\nconst row = $json;\nconst b64 = Buffer.from(JSON.stringify(row)).toString('base64');\nreturn { ...row, tailor_b64: b64 };"
      },
      "id": "ab1cde3d-0d67-4a0b-967a-28956e18f201",
      "name": "Build Tailor Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        300
      ]
    },
    {
      "parameters": {
        "command": "$JOBHUNT_ROOT/.venv/bin/python $JOBHUNT_ROOT/playwright_scripts/tailor.py --input-b64 \"{{$json.tailor_b64}}\""
      },
      "id": "cb1cde3d-0d67-4a0b-967a-28956e18f26a",
      "name": "Call Sonnet Tailor",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1280,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// tailor.py prints one merged JSON object on stdout (role + artifact urls +\n// previews + status). Parse it; on any failure surface a tailor_failed row so\n// the Sheet update still runs and the role is not silently lost.\nlet out;\ntry {\n  out = JSON.parse(($json.stdout || '').trim());\n} catch (e) {\n  out = { ...$json, status: 'tailor_failed', error: 'unparseable stdout: ' + (($json.stdout || '').slice(0, 200)) };\n}\nreturn out;"
      },
      "id": "bc1cde3d-0d67-4a0b-967a-28956e18f202",
      "name": "Parse Tailor Output",
