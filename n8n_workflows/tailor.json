      },
      "id": "f5e1fe1c-d70a-40a2-b258-86d9a187babc",
      "name": "Run LinkedIn Enrichment",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const output = JSON.parse($json.stdout || '{}');\nconst row = $items('Get Queued Roles')[0].json;\n\nrow.hiring_mgr_name = output.hiring_manager?.name || '';\nrow.hiring_mgr_title = output.hiring_manager?.title || '';\nrow.hiring_mgr_linkedin = output.hiring_manager?.linkedin_url || '';\nrow.team_members = JSON.stringify(output.team_members || []);\nrow.referrals = JSON.stringify(output.referrals || []);\n\nreturn row;"
      },
      "id": "d0e1fe1c-d70a-40a2-b258-86d9a187b5bc",
      "name": "Parse Enrichment JSON",
      "type": "n8n-nodes-base.code",
