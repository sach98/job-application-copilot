    {
      "parameters": {
        "jsCode": "const items = $items('Read Applications Sheet');\nconst jobs = items.map(i => i.json);\nconst today = new Date().toISOString().split('T')[0];\n\n// Surface all un-acted roles (everything except applied/skipped) so old\n// reviewed-but-untouched jobs reappear in the queue.\nconst ACTED = new Set(['applied', 'skipped']);\nconst queuedRoles = jobs.filter(j => j.status && !ACTED.has(j.status)).map(j => ({\n  id: j.id || j.jd_url,\n  company: j.company,\n  role: j.role,\n  salary: j.salary,\n  fit_score: parseFloat(j.fit_score || 0),\n  source: j.source,\n  location: j.location,\n  posted_at: j.posted_at,\n  fit_summary_3_bullets: (() => { try { return j.fit_summary ? JSON.parse(j.fit_summary) : []; } catch (e) { return []; } })(),\n  hiring_mgr: {\n    name: j.hiring_mgr_name,\n    title: j.hiring_mgr_title,\n    linkedin_url: j.hiring_mgr_linkedin\n  },\n  jd_excerpt: j.jd_text ? j.jd_text.slice(0, 1000) : '',\n  cl_preview: j.cl_preview || '',\n  cl_url: j.cl_url || '',\n  tailored_resume_diff_preview: j.resume_diff_preview || '',\n  resume_url: j.resume_url || '',\n  team_members: j.team_members || '[]'\n}));\n\nconst todayApplied = jobs.filter(j => j.status === 'applied' && j.applied_at && j.applied_at.startsWith(today)).length;\nconst pendingReview = jobs.filter(j => j.status === 'pending_review').length;\n\nreturn {\n  roles: queuedRoles,\n  cap: 5,\n  today_applied: todayApplied,\n  pending_review_count: pendingReview\n};"
      },
