    {
      "parameters": {
        "jsCode": "// Incoming POST payload lives under .body. Base64-encode it so the shell\n// command never has to quote arbitrary question / JD text. essay.py decodes\n// --input-b64 and injects profile_answers + the role's tailored CL itself.\nconst body = $json.body || $json || {};\nconst b64 = Buffer.from(JSON.stringify(body)).toString('base64');\nreturn { essay_b64: b64 };"
      },
      "id": "ab1cde3d-0d67-4a0b-967a-28956e18f2b1",
      "name": "Build Essay Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        680
      ]
    },
    {
      "parameters": {
        "command": "$JOBHUNT_ROOT/.venv/bin/python $JOBHUNT_ROOT/playwright_scripts/essay.py --input-b64 \"{{$json.essay_b64}}\""
      },
      "id": "cb1cde3d-0d67-4a0b-967a-28956e18f26b",
      "name": "Draft Custom Essay Answer",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        440,
        680
      ]
    },
    {
      "parameters": {
        "jsCode": "// essay.py prints one JSON object on stdout: {answer, char_count,\n// confidence, needs_human_review_reason}. Parse it defensively.\nlet out;\ntry {\n  out = JSON.parse(($json.stdout || '').trim());\n} catch (e) {\n  out = { answer: '', confidence: 0.0, needs_human_review_reason: 'unparseable essay output' };\n}\nreturn out;"
      },
      "id": "bc1cde3d-0d67-4a0b-967a-28956e18f2b2",
      "name": "Parse Essay Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        620,
        680
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ answer: $json.answer || '', confidence: $json.confidence || 0, needs_human_review_reason: $json.needs_human_review_reason || '' }) }}",
        "options": {}
      },
      "id": "fd9e85ca-1a1b-4f9e-bd9d-8d481f8f7c5f",
      "name": "Respond with Essay",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        800,
        680
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || {};\nconst action = body.action;\n\nconst today = new Date();\nconst istOffset = 5.5 * 60 * 60 * 1000;\nconst istTime = new Date(today.getTime() + istOffset);\nconst appliedAt = istTime.toISOString().replace('Z', '+05:30');\n\nconst f1_due_date = new Date(istTime.getTime() + 7 * 24 * 60 * 60 * 1000);\nconst f1_due = f1_due_date.toISOString().split('T')[0];\n\nconst f2_due_date = new Date(istTime.getTime() + 14 * 24 * 60 * 60 * 1000);\nconst f2_due = f2_due_date.toISOString().split('T')[0];\n\nlet status = 'skipped';\nif (action === 'apply') status = 'applied';\nelse if (action === 'save') status = 'queued';\n\nreturn {\n  id: body.role_id,\n  role_id: body.role_id,\n  action: action,\n  status: status,\n  company: body.company,\n  role: body.role,\n  jd_url: body.jd_url,\n  team_members: body.team_members,\n  applied_at: appliedAt,\n  followup_1_due: f1_due,\n  followup_2_due: f2_due\n};"
      },
      "id": "e2cdfe1c-d70a-40a2-b258-86d9a187b411",
      "name": "Prepare Swipe Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        210,
        380
      ]
    },
    {
      "parameters": {
        "jsCode": "const swipeData = $node[\"Prepare Swipe Data\"].json;\nreturn {\n  id: swipeData.id,\n  status: 'applied',\n  applied_at: swipeData.applied_at,\n  followup_1_due: swipeData.followup_1_due,\n  followup_2_due: swipeData.followup_2_due\n};"
      },
      "id": "e2cdfe1c-d70a-40a2-b258-86d9a187b422",
      "name": "Prepare Applied Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ]
    }
